c\\Components\\Admin\\Reservations.jsx",[],"D:\\Proyectos\\bibliotecapp\\frontapp\\src\\Components\\Admin\\Returns.jsx",[],"D:\\Proyectos\\bibliotecapp\\frontapp\\src\\Components\\Categories\\Novelas\\Novela.jsx",[],["159","160"],"D:\\Proyectos\\bibliotecapp\\frontapp\\src\\Components\\Categories\\Novelas\\Novelas.jsx",[],"D:\\Proyectos\\bibliotecapp\\frontapp\\src\\Components\\Categories\\Poemas\\Poemas.jsx",[],"D:\\Proyectos\\bibliotecapp\\frontapp\\src\\Components\\News.jsx",[],"D:\\Proyectos\\bibliotecapp\\frontapp\\src\\Components\\Authors\\dataAuthors.js",[],"D:\\Proyectos\\bibliotecapp\\frontapp\\src\\Config\\config.js",[],"D:\\Proyectos\\bibliotecapp\\frontapp\\src\\Components\\Categories.jsx",[],"D:\\Proyectos\\bibliotecapp\\frontapp\\src\\Components\\Footer.jsx",[],"D:\\Proyectos\\bibliotecapp\\frontapp\\src\\Components\\CardBook.jsx",[],"D:\\Proyectos\\bibliotecapp\\frontapp\\src\\Components\\Search.jsx",[],"D:\\Proyectos\\bibliotecapp\\frontapp\\src\\Components\\CardBooks.jsx",[],"D:\\Proyectos\\bibliotecapp\\frontapp\\src\\Components\\Libraries.jsx",[],"D:\\Proyectos\\bibliotecapp\\frontapp\\src\\Components\\Admin\\Layaout.jsx",[],"D:\\Proyectos\\bibliotecapp\\frontapp\\src\\Styled\\Spinner.jsx",[],"D:\\Proyectos\\bibliotecapp\\frontapp\\src\\Components\\Categories\\CategorieSearch.jsx",[],"D:\\Proyectos\\bibliotecapp\\frontapp\\src\\Components\\Header.jsx",[],"D:\\Proyectos\\bibliotecapp\\frontapp\\src\\Components\\Function\\function.js",[],"D:\\Proyectos\\bibliotecapp\\frontapp\\src\\Components\\Admin\\HeaderAdmin.jsx",[],"D:\\Proyectos\\bibliotecapp\\frontapp\\src\\Components\\SectionFont.jsx",[],"D:\\Proyectos\\bibliotecapp\\frontapp\\src\\Components\\Categories\\Documentaries\\Documentaries.jsx",[],"D:\\Proyectos\\bibliotecapp\\frontapp\\src\\Components\\Categories\\Otros\\Otros.jsx",[],"D:\\Proyectos\\bibliotecapp\\frontapp\\src\\Hooks\\useCount.js",[],"D:\\Proyectos\\bibliotecapp\\frontapp\\src\\Components\\Admin\\FormLoans.jsx",["161"],"import React, {useState,useEffect} from 'react'\r\nimport Layaout from './Layaout';\r\nimport styled from 'styled-components';\r\nimport Spinner from '../../Styled/Spinner';\r\nimport Swal from 'sweetalert2';\r\nimport clienteAxios from '../../Config/config';\r\n\r\nconst StyleForm = styled.div`\r\ndisplay:flex;\r\nalign-items:center;\r\nalign-content:center;\r\n\r\n.center-input{\r\n  display:flex;\r\n  align-items:center;\r\n  align-content:center;\r\n  border-style:none;\r\n  box-shadow: 1px 2px 11px 2px rgba(150, 150, 150, 0.5);\r\n  width:60%;\r\n  margin-right:auto;\r\n  margin-left:auto;\r\n}\r\n\r\n.btn-lg{\r\n  margin:3px;\r\n}\r\n.form-control {\r\n  border: 1px solid rgba(48, 47, 47, 0.5)\r\n}\r\n.card-title h1{\r\n  margin:0.5em;\r\n}\r\n`;\r\nconst FormLoans = ({match}) => {\r\n\r\n  const [loanAdmin,setLoanAdmin] = useState(\"\");\r\n  const [dataUser,setDataUser] = useState(\"\");//crear objeto con los nombre de los inputs\r\n\r\n  useEffect(() => {\r\n    let call = async () => {\r\n      let data = await clienteAxios.get(`get/book/${match.params.id}`);\r\n      setLoanAdmin(data.data.data);\r\n    }\r\n    call();\r\n  }, [match.params.id]);\r\n\r\n  const handelChange = (e) => {\r\n    let {name,value} = e.target;\r\n    setDataUser({\r\n      ...dataUser,\r\n      [name] : value\r\n    })\r\n  }\r\n\r\n  const senData = async () => {\r\n  if(dataUser === \"\"){\r\n    Swal.fire({\r\n      icon: 'error',\r\n      title: 'Oops...',\r\n      text: \"llena todos los campos\",\r\n    });\r\n    return;\r\n  }else{\r\n    Swal.fire(\r\n      'Good job!',\r\n      'You clicked the button!',\r\n      'success'\r\n    );\r\n\r\n    let createLoan = await clienteAxios.post(\"\")\r\n  }\r\n  }\r\n\r\n  let getMont = new Date().getMonth()+1;\r\n  let lastDate = `${new Date(new Date().getFullYear(), getMont, 0).getDate()}`\r\n\r\n  return (\r\n  <Layaout>\r\n    {(!loanAdmin) ? <Spinner/> : (\r\n\r\n        <StyleForm>\r\n          <div className=\"card col-12 center-input \" >\r\n            <div className=\"card-title\">\r\n              <h1>Nuevo Prestamo</h1>\r\n            </div>\r\n            <div className=\"content-form col-10\">\r\n              <form>\r\n                <div className=\"mb-3\">\r\n                  <label htmlFor=\"recipient-name\" className=\"col-form-label\">Nombre Usuario:</label>\r\n                  <input type=\"text\" onChange={handelChange} name=\"name_user\" className=\"form-control\" id=\"recipient-name\" />\r\n                </div>\r\n                <div className=\"mb-3\">\r\n                  <label htmlFor=\"message-text\" className=\"col-form-label\">Numero de Telefono:</label>\r\n                  <input type=\"text\" onChange={handelChange} name=\"mobile_user\" className=\"form-control\" id=\"recipient-mobile\" />\r\n                </div>\r\n                <div className=\"container-label\">\r\n                  <label htmlFor=\"\">Asigna un dia para devolver el Libro</label>\r\n                </div>\r\n                <div className=\"container-date\">\r\n                  <input type=\"date\" onChange={handelChange} className=\"form-control\" name=\"return_loan\" id=\"date\" min={`${new Date().getFullYear()}-${(getMont <= 9) ? (\"0\" + getMont) : (getMont)}-${new Date().getDate()}`} max={`${new Date().getFullYear()}-${(getMont <= 9) ? (\"0\" + getMont) : (getMont)}-${lastDate}`}/>\r\n                </div>\r\n              </form>\r\n            </div>\r\n        \r\n            <button className=\"btn btn-success btn-lg\"  onClick={senData}>Prestar</button>\r\n          </div>\r\n        </StyleForm>\r\n    )}\r\n  </Layaout>\r\n  )\r\n}\r\n\r\nexport default FormLoans\r\n","D:\\Proyectos\\bibliotecapp\\frontapp\\src\\Components\\Admin\\FormAddBook.jsx",[],{"ruleId":"162","replacedBy":"163"},{"ruleId":"164","replacedBy":"165"},{"ruleId":"162","replacedBy":"166"},{"ruleId":"164","replacedBy":"167"},{"ruleId":"168","severity":1,"message":"169","line":70,"column":9,"nodeType":"170","messageId":"171","endLine":70,"endColumn":19},"no-native-reassign",["172"],"no-negated-in-lhs",["173"],["172"],["173"],"no-unused-vars","'createLoan' is assigned a value but never used.","Identifier","unusedVar","no-global-assign","no-unsafe-negation"]